# ENABLER-FIXTURES-E2E — variables d'environnement.
# COPIER en `.env` (gitignored) et renseigner les vraies valeurs. Ce fichier .example ne contient
# QUE des valeurs FACTICES : aucun secret, aucune clé, aucun chemin machine réel n'est versionné.

# Puppeteer — chemin d'entrée du module (machine locale exécutant l'E2E) :
PUPPETEER_PATH=/CHEMIN/LOCAL/node_modules/puppeteer/lib/cjs/puppeteer/puppeteer.js

# Accès SSH recette — la clé privée .pem N'EST JAMAIS versionnée (ni ce .env) :
FIXTURE_SSH_KEY=/CHEMIN/LOCAL/vers/cle-privee.pem
FIXTURE_SSH_HOST=ubuntu@X.X.X.X
FIXTURE_BENCH=/home/ubuntu/bench-admission
FIXTURE_BENCH_BIN=/home/ubuntu/.local/bin/bench
FIXTURE_SITE=api-admission-rec.lanem.bj

# Fronts live (bundles Cloudflare) — management + candidat :
FIXTURE_STAFF_URL=https://staff-rec.lanem.bj
FIXTURE_APPLICANT_URL=https://admission-rec.lanem.bj

# Démo mark_admissible :
FIXTURE_ID=REMPLACER-par-id-du-dossier-ETU-fixture

# Comptes staff par rôle (B-3 — management exhaustive multi-rôles) :
FIXTURE_ADMIN_USER=admin.admissions@lanem.bj
FIXTURE_RESP_USER=resp.recette@lanem.bj
FIXTURE_DIR_USER=direction.recette@lanem.bj
